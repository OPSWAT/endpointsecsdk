#endif

namespace fs = std::filesystem;

PackageExtractor::PackageExtractor() {
}

PackageExtractor::~PackageExtractor() {
    // Cleanup if needed
}

bool PackageExtractor::extractPackage(const std::string& packageFile, const std::string& extractDir) {
    std::cout << "Extracting package: " << packageFile << " to: " << extractDir << std::endl;
    
    // Create extraction directory if it doesn't exist
    fs::create_directories(extractDir);
    
    // Extract based on file extension
    std::string extension = fs::path(packageFile).extension().string();
    
    if (extension == ".zip" || extension == ".ZIP") {
        return extractZipPackage(packageFile, extractDir);
    } else if (extension == ".tar" || extension == ".tgz" || 
               extension == ".gz" || extension == ".bz2" || 
               extension == ".xz") {
        return extractTarPackage(packageFile, extractDir);
    } else {
        std::cerr << "Unsupported package format: " << extension << std::endl;
        return false;
    }
}

bool PackageExtractor::extractZipPackage(const std::string& packageFile, const std::string& extractDir) {
    std::string command;
    
    #ifdef _WIN32
        // Windows: Use PowerShell's Expand-Archive
        command = "powershell -command \"Expand-Archive -Path '" + packageFile + 
                  "' -DestinationPath '" + extractDir + "' -Force\"";
    #else
        // macOS/Linux: Use unzip
        command = "unzip -o '" + packageFile + "' -d '" + extractDir + "'";
    #endif
    
    std::cout << "Running extraction command: " << command << std::endl;
    int result = system(command.c_str());
    
    if (result != 0) {
        std::cerr << "Failed to extract zip package. Error code: " << result << std::endl;
        // Try alternative method if available
        #ifndef _WIN32
            // Try using Python's zipfile module as a fallback
            std::string pyCommand = "python3 -c \"import zipfile; zipfile.ZipFile('" + 
                                   packageFile + "').extractall('" + extractDir + "')\"";
            std::cout << "Trying alternative extraction method: " << pyCommand << std::endl;
            result = system(pyCommand.c_str());
            
            if (result != 0) {
                std::cerr << "Alternative extraction also failed. Error code: " << result << std::endl;
                return false;
            }
        #else
            return false;
        #endif
    }
    
    std::cout << "Package extraction completed successfully" << std::endl;
    return true;
}

bool PackageExtractor::extractTarPackage(const std::string& packageFile, const std::string& extractDir) {
    std::string command;
    
    // Determine tar flags based on extension
    std::string extension = fs::path(packageFile).extension().string();
    std::string flags = "xf";
    
    if (extension == ".gz" || extension == ".tgz") {
        flags = "xzf";
    } else if (extension == ".bz2") {
        flags = "xjf";
    } else if (extension == ".xz") {
        flags = "xJf";
    }
    
    #ifdef _WIN32
        // Windows might not have tar, try to use 7z if available
        command = "7z x \"" + packageFile + "\" -o\"" + extractDir + "\" -y";
    #else
        // macOS/Linux: Use tar with appropriate flags
        command = "tar " + flags + " '" + packageFile + "' -C '" + extractDir + "'";
    #endif
    
    std::cout << "Running extraction command: " << command << std::endl;
    int result = system(command.c_str());
    
    if (result != 0) {
        std::cerr << "Failed to extract tar package. Error code: " << result << std::endl;
        
        // Try alternative method if first one failed
        #ifdef _WIN32
            // Try Python's tarfile module as a fallback on Windows
            std::string pyCommand = "python -c \"import tarfile; tarfile.open('" + 
                                   packageFile + "').extractall('" + extractDir + "')\"";
            std::cout << "Trying alternative extraction method: " << pyCommand << std::endl;
            result = system(pyCommand.c_str());
            
            if (result != 0) {
                std::cerr << "Alternative extraction also failed. Error code: " << result << std::endl;
                return false;
            }
        #else
            // On Unix systems, try a different tar implementation
            if (extension == ".gz" || extension == ".tgz") {
                command = "gunzip -c '" + packageFile + "' | tar -x -C '" + extractDir + "'";
            } else if (extension == ".bz2") {
                command = "bunzip2 -c '" + packageFile + "' | tar -x -C '" + extractDir + "'";
            } else if (extension == ".xz") {
                command = "unxz -c '" + packageFile + "' | tar -x -C '" + extractDir + "'";
            } else {
                return false;
            }
            
            std::cout << "Trying alternative extraction method: " << command << std::endl;
            result = system(command.c_str());
            
            if (result != 0) {
                std::cerr << "Alternative extraction also failed. Error code: " << result << std::endl;
                return false;
            }
        #endif
    }
    
    std::cout << "Package extraction completed successfully" << std::endl;
    return true;
}

std::string PackageExtractor::findBinDirectory(const std::string& extractDir) {
    // Try to locate the bin directory in the extracted files
    std::vector<std::string> possibleBinDirs = {
        "/bin",
        "/Bin",
        "/lib",
        "/Lib"
    };

    // First, try to find directories directly
    for (const auto& binDir : possibleBinDirs) {
        std::string fullPath = extractDir + binDir;
        if (fs::exists(fullPath) && fs::is_directory(fullPath)) {
            return fullPath;
        }
    }

    // Then, try to find in subdirectories (one level)
    for (const auto& entry : fs::directory_iterator(extractDir)) {
        if (entry.is_directory()) {
            for (const auto& binDir : possibleBinDirs) {
                std::string fullPath = entry.path().string() + binDir;
                if (fs::exists(fullPath) && fs::is_directory(fullPath)) {
                    return fullPath;
                }
            }
        }
    }

    // If we can't find it, look for the deepest directory with library files
    for (const auto& entry : fs::recursive_directory_iterator(extractDir)) {
        if (entry.is_regular_file()) {
            std::string filename = entry.path().filename().string();
            if (filename.find("waapi") != std::string::npos &&
                (filename.find(".dll") != std::string::npos ||
                 filename.find(".so") != std::string::npos ||
                 filename.find(".dylib") != std::string::npos)) {
                return entry.path().parent_path().string();
            }
        }
    }

    // Not found
    std::cerr << "Warning: Could not find bin directory in extracted files" << std::endl;
    return "";
}

bool PackageExtractor::copyExtractedFiles(const std::string& extractDir, const std::string& sdkDir, const std::string& vapmDir) {
    try {
        // Create necessary directories
        fs::create_directories(fs::path(sdkDir) / "lib");
        fs::create_directories(fs::path(sdkDir) / "include");
        fs::create_directories(vapmDir);
        
        // Get current platform and architecture
        std::string platform = getCurrentPlatform();
        std::string arch = getCurrentArchitecture();
        
        std::cout << "Detected platform: " << platform << ", architecture: " << arch << std::endl;
        
        // Copy include files regardless of platform
        copyIncludeFiles(extractDir, sdkDir);
        
        // Copy platform-specific libraries
        if (platform == "windows") {
            copyWindowsLibs(extractDir, sdkDir, arch);
        } else if (platform == "macos") {
            copyMacOsLibs(extractDir, sdkDir, arch);
        } else if (platform == "linux") {
            copyLinuxLibs(extractDir, sdkDir, arch);
        } else {
            std::cerr << "Unknown platform: " << platform << std::endl;
            return false;
        }
        
        // Copy VAPM files
        copyVapmFiles(extractDir, vapmDir);
        
        return true;
    } catch (const std::exception& e) {
        std::cerr << "Error copying files: " << e.what() << std::endl;
        return false;
    }
}

void PackageExtractor::copyWindowsLibs(const std::string& extractDir, const std::string& sdkDir, const std::string& arch) {
    std::cout << "Copying Windows libraries..." << std::endl;
    
    // Target directory
    fs::path targetLibDir = fs::path(sdkDir) / "lib";
    fs::create_directories(targetLibDir);
    
    // Use glob patterns to find all DLL and LIB files recursively
    std::vector<fs::path> libFiles;
    bool foundLibs = false;
    
    try {
        std::cout << "Searching for " << arch << " .dll and .lib files in: " << extractDir << std::endl;
        
        // Search recursively for all DLL and LIB files
        for (const auto& entry : fs::recursive_directory_iterator(extractDir)) {
            if (entry.is_regular_file()) {
                std::string ext = entry.path().extension().string();
                if (ext == ".dll" || ext == ".lib") {
                    // Check if it's in an architecture-specific directory
                    std::string pathStr = entry.path().string();
                    std::transform(pathStr.begin(), pathStr.end(), pathStr.begin(), ::tolower);
                    
                    // Only copy files from directories matching our architecture or from non-architecture specific paths
                    if (pathStr.find("/" + arch + "/") != std::string::npos || 
                        pathStr.find("\\" + arch + "\\") != std::string::npos ||
                        (pathStr.find("/x86/") == std::string::npos && 
                         pathStr.find("/x64/") == std::string::npos && 
                         pathStr.find("/arm64/") == std::string::npos &&
                         pathStr.find("\\x86\\") == std::string::npos && 
                         pathStr.find("\\x64\\") == std::string::npos && 
                         pathStr.find("\\arm64\\") == std::string::npos)) {
                        
                        libFiles.push_back(entry.path());
                        foundLibs = true;
                        
                        // Copy the file
                        fs::copy_file(entry.path(), targetLibDir / entry.path().filename(), 
                                     fs::copy_options::overwrite_existing);
                        std::cout << "Copied: " << entry.path().filename().string() << std::endl;
                    }
                }
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error while searching for Windows libraries: " << e.what() << std::endl;
    }
    
    if (!foundLibs) {
        std::cerr << "Warning: Could not find Windows libraries for architecture: " << arch << std::endl;
    } else {
        std::cout << "Successfully copied " << libFiles.size() << " Windows libraries" << std::endl;
    }
}

void PackageExtractor::copyMacOsLibs(const std::string& extractDir, const std::string& sdkDir, const std::string& arch) {
    std::cout << "Copying macOS libraries..." << std::endl;
    
    // Target directory
    fs::path targetLibDir = fs::path(sdkDir) / "lib";
    fs::create_directories(targetLibDir);
    
    // Use glob patterns to find all dylib files recursively
    std::vector<fs::path> dylibs;
    bool foundLibs = false;
    
    try {
        std::cout << "Searching for dylib files in: " << extractDir << std::endl;
        
        // Search recursively for all dylib files
        for (const auto& entry : fs::recursive_directory_iterator(extractDir)) {
            if (entry.is_regular_file()) {
                std::string ext = entry.path().extension().string();
                if (ext == ".dylib" || ext == ".a" || ext == ".framework") {
                    dylibs.push_back(entry.path());
                    foundLibs = true;
                    
                    // Copy the file
                    fs::copy_file(entry.path(), targetLibDir / entry.path().filename(), 
                                 fs::copy_options::overwrite_existing);
                    std::cout << "Copied: " << entry.path().filename().string() << std::endl;
                }
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error while searching for macOS libraries: " << e.what() << std::endl;
    }
    
    if (!foundLibs) {
        std::cerr << "Warning: Could not find macOS libraries" << std::endl;
    } else {
        std::cout << "Successfully copied " << dylibs.size() << " macOS libraries" << std::endl;
    }
}

void PackageExtractor::copyLinuxLibs(const std::string& extractDir, const std::string& sdkDir, const std::string& arch) {
    std::cout << "Copying Linux libraries..." << std::endl;
    
    // Target directory
    fs::path targetLibDir = fs::path(sdkDir) / "lib";
    fs::create_directories(targetLibDir);
    
    // Use glob patterns to find all .so and .a files recursively
    std::vector<fs::path> libFiles;
    bool foundLibs = false;
    
    try {
        std::cout << "Searching for " << arch << " .so and .a files in: " << extractDir << std::endl;
        
        // Search recursively for all .so and .a files
        for (const auto& entry : fs::recursive_directory_iterator(extractDir)) {
            if (entry.is_regular_file()) {
                std::string ext = entry.path().extension().string();
                if (ext == ".so" || ext == ".a") {
                    // Check if it's in an architecture-specific directory
                    std::string pathStr = entry.path().string();
                    std::transform(pathStr.begin(), pathStr.end(), pathStr.begin(), ::tolower);
                    
                    // Only copy files from directories matching our architecture or from non-architecture specific paths
                    if (pathStr.find("/" + arch + "/") != std::string::npos || 
                        pathStr.find("\\" + arch + "\\") != std::string::npos ||
                        (pathStr.find("/x86/") == std::string::npos && 
                         pathStr.find("/x64/") == std::string::npos && 
                         pathStr.find("/arm64/") == std::string::npos &&
                         pathStr.find("\\x86\\") == std::string::npos && 
                         pathStr.find("\\x64\\") == std::string::npos && 
                         pathStr.find("\\arm64\\") == std::string::npos)) {
                        
                        libFiles.push_back(entry.path());
                        foundLibs = true;
                        
                        // Copy the file
                        fs::copy_file(entry.path(), targetLibDir / entry.path().filename(), 
                                     fs::copy_options::overwrite_existing);
                        std::cout << "Copied: " << entry.path().filename().string() << std::endl;
                    }
                }
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error while searching for Linux libraries: " << e.what() << std::endl;
    }
    
    if (!foundLibs) {
        std::cerr << "Warning: Could not find Linux libraries for architecture: " << arch << std::endl;
    } else {
        std::cout << "Successfully copied " << libFiles.size() << " Linux libraries" << std::endl;
    }
}

void PackageExtractor::copyIncludeFiles(const std::string& extractDir, const std::string& sdkDir) {
    std::cout << "Copying include files..." << std::endl;
    
    // Target directory
    fs::path targetIncludeDir = fs::path(sdkDir) / "include";
    fs::create_directories(targetIncludeDir);
    
    // First check common include directories
    std::vector<fs::path> sourceIncludeDirs = {
        fs::path(extractDir) / "include",
        fs::path(extractDir) / "headers",
        fs::path(extractDir) / "inc"
    };
    
    bool foundHeaders = false;
    
    // First try copying from standard include directories
    for (const auto& includeDir : sourceIncludeDirs) {
        if (fs::exists(includeDir)) {
            std::cout << "Found include files in: " << includeDir.string() << std::endl;
            
            // Copy all files and subdirectories from include directory
            for (const auto& entry : fs::recursive_directory_iterator(includeDir)) {
                fs::path relativePath = fs::relative(entry.path(), includeDir);
                fs::path targetPath = targetIncludeDir / relativePath;
                
                if (entry.is_directory()) {
                    fs::create_directories(targetPath);
                } else if (entry.is_regular_file()) {
                    fs::create_directories(targetPath.parent_path());
                    fs::copy_file(entry.path(), targetPath, fs::copy_options::overwrite_existing);
                    std::cout << "Copied include file: " << relativePath.string() << std::endl;
                    foundHeaders = true;
                }
            }
        }
    }
    
    // If no headers found in standard directories, use glob to find .h files
    if (!foundHeaders) {
        std::cout << "Searching for header files using glob pattern..." << std::endl;
        
        try {
            // Search for all .h files recursively
            for (const auto& entry : fs::recursive_directory_iterator(extractDir)) {
                if (entry.is_regular_file()) {
                    std::string ext = entry.path().extension().string();
                    if (ext == ".h" || ext == ".hpp") {
                        // Copy to flat include directory
                        fs::create_directories(targetIncludeDir);
                        fs::copy_file(entry.path(), targetIncludeDir / entry.path().filename(), 
                                     fs::copy_options::overwrite_existing);
                        std::cout << "Copied header: " << entry.path().filename().string() << std::endl;
                        foundHeaders = true;
                    }
                }
            }
        } catch (const std::exception& e) {
            std::cerr << "Error while searching for header files: " << e.what() << std::endl;
        }
    }
    
    if (!foundHeaders) {
        std::cerr << "Warning: Could not find any header files." << std::endl;
    }
}

void PackageExtractor::copyVapmFiles(const std::string& extractDir, const std::string& vapmDir) {
    std::cout << "Copying VAPM files..." << std::endl;
    
    // Define possible VAPM directories
    std::vector<fs::path> vapmDirs = {
        fs::path(extractDir) / "vapm",
        fs::path(extractDir) / "VAPM",
        fs::path(extractDir) / "va_plugins"
    };
    
    bool foundVapmDir = false;
    
    // Try each potential VAPM directory
    for (const auto& sourceVapmDir : vapmDirs) {
        if (fs::exists(sourceVapmDir)) {
            std::cout << "Found VAPM files in: " << sourceVapmDir.string() << std::endl;
            
            // Copy all files and subdirectories from VAPM directory
            for (const auto& entry : fs::recursive_directory_iterator(sourceVapmDir)) {
                fs::path relativePath = fs::relative(entry.path(), sourceVapmDir);
                fs::path targetPath = fs::path(vapmDir) / relativePath;
                
                if (entry.is_directory()) {
                    fs::create_directories(targetPath);
                } else if (entry.is_regular_file()) {
                    fs::create_directories(targetPath.parent_path());
                    fs::copy_file(entry.path(), targetPath, fs::copy_options::overwrite_existing);
                }
            }
            
            foundVapmDir = true;
            break;
        }
    }
    
    if (!foundVapmDir) {
        std::cerr << "Warning: Could not find VAPM directory." << std::endl;
    }
}

std::string PackageExtractor::getCurrentPlatform() {
    #ifdef _WIN32
        return "windows";
    #elif __APPLE__
        return "macos";
    #elif __linux__
        return "linux";
    #else
        return "unknown";
    #endif
}

std::string PackageExtractor::getCurrentArchitecture() {
    #ifdef _WIN32
        #ifdef _WIN64
            return "x64";
        #else
            return "x86";
        #endif
    #elif __APPLE__
        #ifdef __arm64__
            return "arm64";
        #else
            return "x64";
        #endif
    #elif __linux__
        struct utsname buffer;
        if (uname(&buffer) == 0) {
            if (strcmp(buffer.machine, "x86_64") == 0) {
                return "x64";
            } else if (strcmp(buffer.machine, "i686") == 0) {
                return "x86";
            } else if (strcmp(buffer.machine, "aarch64") == 0 || 
                       strcmp(buffer.machine, "arm64") == 0) {
                return "arm64";
            }
        }
        return "unknown";
    #else
        return "unknown";
    #endif
}

std::vector<fs::path> PackageExtractor::findFiles(const fs::path& directory, const std::string& extension) {
    std::vector<fs::path> result;
    
    if (!fs::exists(directory) || !fs::is_directory(directory)) {
        std::cout << "Warning: Directory does not exist: " << directory.string() << std::endl;
        return result;
    }
    
    try {
        for (const auto& entry : fs::recursive_directory_iterator(directory)) {
            if (fs::is_regular_file(entry) && entry.path().extension() == extension) {
                result.push_back(entry.path());
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error while searching for files: " << e.what() << std::endl;
    }
    
    return result;
}

std::vector<fs::path> PackageExtractor::findDirectories(const fs::path& directory, const std::string& namePattern) {
    std::vector<fs::path> result;
    
    if (!fs::exists(directory) || !fs::is_directory(directory)) {
        std::cout << "Warning: Directory does not exist: " << directory.string() << std::endl;
        return result;
    }
    
    try {
        for (const auto& entry : fs::recursive_directory_iterator(directory)) {
            if (fs::is_directory(entry)) {
                std::string dirName = entry.path().filename().string();
                if (dirName.find(namePattern) != std::string::npos) {
                    result.push_back(entry.path());
                }
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error while searching for directories: " << e.what() << std::endl;
    }
    
    return result;
}

void PackageExtractor::listDirectoryContents(const fs::path& directory, int depth) {
    if (!fs::exists(directory) || !fs::is_directory(directory)) {
        std::cout << "Directory does not exist: " << directory.string() << std::endl;
        return;
    }
    
    std::cout << "Contents of " << directory.string() << ":" << std::endl;
    
    try {
        for (const auto& entry : fs::directory_iterator(directory)) {
            std::string indentation(depth * 2, ' ');
            std::cout << indentation << entry.path().filename().string();
            
            if (fs::is_directory(entry)) {
                std::cout << " [DIR]";
                if (depth < 3) { // Limit recursion depth
                    std::cout << std::endl;
                    listDirectoryContents(entry.path(), depth + 1);
                } else {
                    std::cout << " ..." << std::endl;
                }
            } else if (fs::is_regular_file(entry)) {
                std::cout << " [" << fs::file_size(entry) << " bytes]" << std::endl;
            } else {
                std::cout << " [OTHER]" << std::endl;
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error while listing directory contents: " << e.what() << std::endl;
    }
}

bool PackageExtractor::isValidExtractedPackage(const fs::path& extractDir) {
    // Check for common directories that should exist in a valid SDK package
    bool hasInclude = false;
    bool hasLib = false;
    bool hasPlatformSpecific = false;
    
    try {
        for (const auto& entry : fs::recursive_directory_iterator(extractDir, fs::directory_options::skip_permission_denied)) {
            if (fs::is_directory(entry)) {
                std::string dirName = entry.path().filename().string();
                std::transform(dirName.begin(), dirName.end(), dirName.begin(), ::tolower);
                
                if (dirName == "include") {
                    hasInclude = true;
                } else if (dirName == "lib") {
                    hasLib = true;
                } else if (dirName.find("win") != std::string::npos || 
                          dirName.find("mac") != std::string::npos || 
                          dirName.find("linux") != std::string::npos) {
                    hasPlatformSpecific = true;
                }
                
                // Early exit if we found all required directories
                if (hasInclude && (hasLib || hasPlatformSpecific)) {
                    return true;
                }
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Error while validating package: " << e.what() << std::endl;
        return false;
    }
    
    std::cout << "Package validation results - Include: " << (hasInclude ? "Yes" : "No") 
              << ", Lib: " << (hasLib ? "Yes" : "No") 
              << ", Platform dirs: " << (hasPlatformSpecific ? "Yes" : "No") << std::endl;
              
    return hasInclude && (hasLib || hasPlatformSpecific);
}

bool PackageExtractor::createFlatSDKStructure(const fs::path& extractDir, const fs::path& outputDir) {
    try {
        if (!fs::exists(extractDir)) {
            std::cerr << "Error: Extract directory does not exist: " << extractDir << std::endl;
            return false;
        }

        if (!fs::exists(outputDir)) {
            fs::create_directories(outputDir);
        }

        // Create standard directories
        fs::path includeDir = outputDir / "include";
        fs::path libDir = outputDir / "lib";
        fs::path binDir = outputDir / "bin";
        
        fs::create_directories(includeDir);
        fs::create_directories(libDir);
        fs::create_directories(binDir);

        std::string platform = getCurrentPlatform();
        std::string arch = getCurrentArchitecture();
        
        std::cout << "Creating flat SDK structure for " << platform << " " << arch << std::endl;
        
        // Copy header files
        std::vector<fs::path> headerFiles = findFiles(extractDir, ".h");
        headerFiles = findFiles(extractDir, ".hpp"); // Add .hpp files
        
        for (const auto& headerFile : headerFiles) {
            // Skip files in build or test directories
            std::string pathStr = headerFile.string();
            if (pathStr.find("/build/") != std::string::npos || 
                pathStr.find("/test/") != std::string::npos ||
                pathStr.find("\\build\\") != std::string::npos || 
                pathStr.find("\\test\\") != std::string::npos) {
                continue;
            }
            
            fs::path destPath = includeDir / headerFile.filename();
            std::cout << "Copying " << headerFile.filename() << " to " << destPath << std::endl;
            fs::copy_file(headerFile, destPath, fs::copy_options::overwrite_existing);
        }
        
        // Find and copy library files based on platform
        std::vector<fs::path> libFiles;
        if (platform == "Windows") {
            // Windows libraries (.lib, .dll)
            libFiles = findFiles(extractDir, ".lib");
            std::vector<fs::path> dllFiles = findFiles(extractDir, ".dll");
            libFiles.insert(libFiles.end(), dllFiles.begin(), dllFiles.end());
        } else if (platform == "macOS") {
            // macOS libraries (.dylib, .a)
            libFiles = findFiles(extractDir, ".dylib");
            std::vector<fs::path> aFiles = findFiles(extractDir, ".a");
            libFiles.insert(libFiles.end(), aFiles.begin(), aFiles.end());
        } else if (platform == "Linux") {
            // Linux libraries (.so, .a)
            libFiles = findFiles(extractDir, ".so");
            std::vector<fs::path> aFiles = findFiles(extractDir, ".a");
            libFiles.insert(libFiles.end(), aFiles.begin(), aFiles.end());
        }
        
        // Copy library files
        for (const auto& libFile : libFiles) {
            fs::path destPath;
            if (libFile.extension() == ".dll") {
                destPath = binDir / libFile.filename();
            } else {
                destPath = libDir / libFile.filename();
            }
            std::cout << "Copying " << libFile.filename() << " to " << destPath << std::endl;
            fs::copy_file(libFile, destPath, fs::copy_options::overwrite_existing);
        }
        
        // Copy any binaries or executables
        std::vector<fs::path> exeFiles;
        if (platform == "Windows") {
            exeFiles = findFiles(extractDir, ".exe");
        } else {
            // Find executable files by checking permissions for Unix platforms
            std::vector<fs::path> allFiles;
            for (const auto& entry : fs::recursive_directory_iterator(extractDir)) {
                if (fs::is_regular_file(entry) && (fs::status(entry).permissions() & 
                    fs::perms::owner_exec) != fs::perms::none) {
                    allFiles.push_back(entry.path());
                }
            }
            exeFiles = allFiles;
        }
        
        // Copy executable files
        for (const auto& exeFile : exeFiles) {
            fs::path destPath = binDir / exeFile.filename();
            std::cout << "Copying " << exeFile.filename() << " to " << destPath << std::endl;
            fs::copy_file(exeFile, destPath, fs::copy_options::overwrite_existing);
        }
        
        return true;
    } catch (const std::exception& e) {
        std::cerr << "Error creating flat SDK structure: " << e.what() << std::endl;
        return false;
    }
}
