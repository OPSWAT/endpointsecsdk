#include <iostream>

namespace fs = std::filesystem;

CatalogDownloader::CatalogDownloader(const std::string& vapmDir, const std::string& workDir)
    : vapmDirectory_(vapmDir),
      workingDirectory_(workDir) {
    
    stageDirectory_ = workingDirectory_ + "/stage";
}

bool CatalogDownloader::downloadAndSetupCatalog(const std::string& downloadToken) {
    try {
        // Create directories
        fs::create_directories(stageDirectory_);
        
        // Download analog.zip
        std::string catalogUrl = "https://vcr.opswat.com/gw/file/download/analog.zip?type=1&token=" + downloadToken;
        std::string catalogOutputPath = stageDirectory_ + "/analog.zip";
        
        std::cout << "Downloading catalog package (analog.zip)" << std::endl;
        
        if (!downloadManager_.downloadToFile(catalogUrl, catalogOutputPath)) {
            std::cerr << "Failed to download catalog package" << std::endl;
            return false;
        }
        
        // Extract the package
        std::string extractPath = stageDirectory_ + "/analog";
        if (!packageExtractor_.extractPackage(catalogOutputPath, extractPath)) {
            std::cerr << "Failed to extract catalog package" << std::endl;
            return false;
        }
        
        // Copy catalog files to VAPM directory
        if (fs::exists(extractPath + "/client")) {
            std::cout << "Setting up catalog files..." << std::endl;
            
            // Create VAPM directory
            fs::create_directories(vapmDirectory_);
            
            // Clear existing content
            if (fs::exists(vapmDirectory_)) {
                for (const auto& entry : fs::directory_iterator(vapmDirectory_)) {
                    fs::remove_all(entry.path());
                }
            }
            
            // Copy client directory
            fs::path sourcePath = fs::path(extractPath) / "client";
            
            packageExtractor_.copyExtractedFiles(extractPath, "", vapmDirectory_);
            
            std::cout << "Catalog files installed successfully to: " << fs::absolute(vapmDirectory_) << std::endl;
        } else {
            std::cerr << "Client directory not found in extracted catalog package" << std::endl;
            return false;
        }
        
        return true;
    } catch (const std::exception& e) {
        std::cerr << "Error downloading catalog files: " << e.what() << std::endl;
        return false;
    }
}
